@api_router.get("/stats/organizer", response_model=StatsResponse)
async def get_organizer_stats(current_user: dict = Depends(get_current_user)):
    if current_user["role"] not in ["organizer", "admin"]:
        raise HTTPException(status_code=403, detail="Solo organizadores pueden ver estadísticas")
    
    total_events = await db.events.count_documents({"organizer_id": current_user["id"]})
    
    pipeline = [
        {"$match": {"organizer_id": current_user["id"]}},
        {"$group": {"_id": None, "total_views": {"$sum": "$views"}, "total_saves": {"$sum": "$saves"}}}
    ]
    stats = await db.events.aggregate(pipeline).to_list(1)
    
    total_views = stats[0]["total_views"] if stats else 0
    total_saves = stats[0]["total_saves"] if stats else 0
    
    now = datetime.now(timezone.utc)
    month_start = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0).isoformat()
    events_this_month = await db.events.count_documents({
        "organizer_id": current_user["id"],
        "created_at": {"$gte": month_start}
    })
    
    return StatsResponse(
        total_events=total_events,
        total_views=total_views,
        total_saves=total_saves,
        events_this_month=events_this_month
    )

