        raise HTTPException(status_code=403, detail="Solo organizadores pueden actualizar plan")
    
    # MOCK: In future, integrate Stripe here
    now = datetime.now(timezone.utc).isoformat()
    await db.users.update_one(
        {"id": current_user["id"]},
        {"$set": {"plan": "pro", "plan_started": now}}
    )
    
    return PlanUpgradeResponse(
        success=True,
        message="Tu frecuencia ahora tiene mayor alcance. Plan Pro activado.",
        plan="pro"
    )

@api_router.post("/plan/cancel", response_model=PlanUpgradeResponse)
async def cancel_plan(current_user: dict = Depends(get_current_user)):
    await db.users.update_one(
        {"id": current_user["id"]},
        {"$set": {"plan": "free", "plan_started": None}}
    )
    
    return PlanUpgradeResponse(
        success=True,
        message="Plan cancelado. Volviste al plan gratuito.",
        plan="free"
    )

