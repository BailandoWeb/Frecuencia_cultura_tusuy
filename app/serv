@api_router.get("/events", response_model=List[EventResponse])
async def get_events(
    category: Optional[str] = None,
    district: Optional[str] = None,
    date_from: Optional[str] = None,
    date_to: Optional[str] = None,
    is_free: Optional[bool] = None,
    featured: Optional[bool] = None,
    search: Optional[str] = None,
    organizer_id: Optional[str] = None,
    limit: int = Query(default=50, le=100),
    skip: int = 0
):
    query = {}
    
    if category:
        cat = await db.categories.find_one({"slug": category}, {"_id": 0})
        if cat:
            query["category_id"] = cat["id"]
    
    if district:
        query["district"] = district
    
    if date_from:
        query["date"] = {"$gte": date_from}
    
    if date_to:
        if "date" in query:
            query["date"]["$lte"] = date_to
        else:
            query["date"] = {"$lte": date_to}
    
    if is_free is not None:
        query["is_free"] = is_free
    
    if featured is not None:
        query["featured"] = featured
    
    if organizer_id:
        query["organizer_id"] = organizer_id
    
    if search:
        query["$or"] = [
            {"title": {"$regex": search, "$options": "i"}},
            {"description": {"$regex": search, "$options": "i"}}
        ]
    
    events = await db.events.find(query, {"_id": 0}).sort("date", 1).skip(skip).limit(limit).to_list(limit)
    
    # Enrich with category and organizer info
    for event in events:
        cat = await db.categories.find_one({"id": event["category_id"]}, {"_id": 0})
        if cat:
            event["category_name"] = cat["name"]
        
        org = await db.users.find_one({"id": event["organizer_id"]}, {"_id": 0})
        if org:
            event["organizer_name"] = org["name"]
            event["organizer_avatar"] = org.get("avatar_url")
    
    return events

