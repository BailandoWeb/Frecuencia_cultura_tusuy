@api_router.post("/events", response_model=EventResponse)
async def create_event(event_data: EventCreate, current_user: dict = Depends(get_current_user)):
    if current_user["role"] not in ["organizer", "admin"]:
        raise HTTPException(status_code=403, detail="Solo organizadores pueden crear eventos")
    
    # Check plan limits (free plan: 2 events/month)
    if current_user.get("plan", "free") == "free":
        now = datetime.now(timezone.utc)
        month_start = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0).isoformat()
        events_this_month = await db.events.count_documents({
            "organizer_id": current_user["id"],
            "created_at": {"$gte": month_start}
        })
        if events_this_month >= 2:
            raise HTTPException(
                status_code=403, 
                detail="Has alcanzado el límite del plan gratuito. Amplifica tu frecuencia con el Plan Pro."
            )
    
    event_id = str(uuid.uuid4())
    now = datetime.now(timezone.utc).isoformat()
    
    event_doc = {
        "id": event_id,
        **event_data.model_dump(),
        "organizer_id": current_user["id"],
        "featured": False,
        "views": 0,
        "saves": 0,
        "created_at": now
    }
    
    await db.events.insert_one(event_doc)
    
    # Update organizer events count
    await db.users.update_one({"id": current_user["id"]}, {"$inc": {"events_count": 1}})
    
    cat = await db.categories.find_one({"id": event_data.category_id}, {"_id": 0})
    event_doc["category_name"] = cat["name"] if cat else None
    event_doc["organizer_name"] = current_user["name"]
    event_doc["organizer_avatar"] = current_user.get("avatar_url")
    
    return event_doc

@api_router.put("/events/{event_id}", response_model=EventResponse)
async def update_event(event_id: str, update_data: EventUpdate, current_user: dict = Depends(get_current_user)):
    event = await db.events.find_one({"id": event_id}, {"_id": 0})
    if not event:
        raise HTTPException(status_code=404, detail="Evento no encontrado")
    
    if event["organizer_id"] != current_user["id"] and current_user["role"] != "admin":
        raise HTTPException(status_code=403, detail="No tienes permiso para editar este evento")
    
    update_dict = {k: v for k, v in update_data.model_dump().items() if v is not None}
    if update_dict:
        await db.events.update_one({"id": event_id}, {"$set": update_dict})
    
    updated_event = await db.events.find_one({"id": event_id}, {"_id": 0})
    
    cat = await db.categories.find_one({"id": updated_event["category_id"]}, {"_id": 0})
    updated_event["category_name"] = cat["name"] if cat else None
    updated_event["organizer_name"] = current_user["name"]
    updated_event["organizer_avatar"] = current_user.get("avatar_url")
    
    return updated_event

@api_router.delete("/events/{event_id}")
async def delete_event(event_id: str, current_user: dict = Depends(get_current_user)):
    event = await db.events.find_one({"id": event_id}, {"_id": 0})
    if not event:
        raise HTTPException(status_code=404, detail="Evento no encontrado")
    
    if event["organizer_id"] != current_user["id"] and current_user["role"] != "admin":
        raise HTTPException(status_code=403, detail="No tienes permiso para eliminar este evento")
    
    await db.events.delete_one({"id": event_id})
    await db.favorites.delete_many({"event_id": event_id})
    await db.users.update_one({"id": current_user["id"]}, {"$inc": {"events_count": -1}})
    
    return {"success": True, "message": "Evento eliminado"}

